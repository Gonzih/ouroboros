{
  "name": "@ouroboros/gateway",
  "version": "2.3.9",
  "description": "ChannelAdapter: Telegram, Slack, webhook. Notification dispatch.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./oidc": {
      "import": "./dist/oidc.js",
      "types": "./dist/oidc.d.ts"
    }
  },
  "files": ["dist", "README.md"],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ouroboros-ai/ouroboros",
    "directory": "packages/gateway"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "test": "vitest run"
  },
  "dependencies": {
    "@ouroboros/core": "workspace:*",
    "express": "^4.21.2",
    "jose": "^6.2.2",
    "node-telegram-bot-api": "^0.66.0"
  },
  "devDependencies": {
    "typescript": "5.7.3",
    "@types/express": "^4.17.21",
    "@types/node": "22.10.7",
    "@types/node-telegram-bot-api": "^0.64.0",
    "vitest": "^1.6.0"
  }
}
