{
  "name": "@ouroboros/core",
  "version": "2.3.9",
  "description": "Shared types, Postgres client, logger, event bus",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist", "README.md"],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ouroboros-ai/ouroboros",
    "directory": "packages/core"
  },
  "scripts": {
    "build": "tsc && cp src/migrations/*.sql dist/migrations/",
    "postbuild": "cp -r src/migrations dist/migrations",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "test": "vitest run"
  },
  "dependencies": {
    "postgres": "3.4.5"
  },
  "devDependencies": {
    "typescript": "5.7.3",
    "@types/node": "22.10.7",
    "vitest": "^1.6.0"
  }
}
