# Ouroboros Environment Variables
# Copy to .env and fill in values before running

# ── Required ────────────────────────────────────────────────────────────────

# Postgres connection string (single DB for all state)
DATABASE_URL=postgres://ouroboros:ouroboros@localhost:5432/ouroboros

# OAuth token for claude CLI subprocesses spawned by meta-agent
CLAUDE_CODE_OAUTH_TOKEN=

# Absolute path to ouroboros repo checkout (used by self-evolution PR flow)
OURO_REPO_ROOT=

# ── Optional: Git backend ────────────────────────────────────────────────────

# GitHub personal access token (for git-backend worker)
GITHUB_TOKEN=

# ── Optional: Gateway channels ───────────────────────────────────────────────

# Telegram bot token (from @BotFather)
TELEGRAM_BOT_TOKEN=
# Telegram chat/group ID to send notifications to
TELEGRAM_CHAT_ID=

# Slack bot OAuth token
SLACK_BOT_TOKEN=
# Slack channel ID (e.g. C01234567)
SLACK_CHANNEL_ID=
# Slack signing secret — enables inbound /approve and /reject via Events API
# SLACK_SIGNING_SECRET=

# Discord bot token (from Discord Developer Portal)
DISCORD_BOT_TOKEN=
# Discord channel ID to send notifications to
DISCORD_CHANNEL_ID=
# Discord app public key — enables inbound /approve, /reject, /status, /jobs via Interactions API
# Set the interactions endpoint URL in Discord Developer Portal to: https://your-host/discord/interactions
# DISCORD_PUBLIC_KEY=

# Generic outbound webhook URL for notification dispatch
OURO_WEBHOOK_URL=

# ── Optional: Service ports ──────────────────────────────────────────────────

# UI server port (default: 7702)
PORT_UI=7702

# MCP factory server port (default: 7703)
PORT_MCP_FACTORY=7703

# Maximum concurrent worker processes (default: 3)
OURO_MAX_WORKERS=3

# ── Optional: Coordinator mode ───────────────────────────────────────────────

# Set to true to use v0.1 Node.js polling loops instead of persistent Claude session (v0.2 default)
OURO_LEGACY_LOOPS=false

# Watchdog loop interval in milliseconds (default: 60000 = 1 minute)
# OURO_WATCHDOG_INTERVAL_MS=60000

# ── Optional: Auth ───────────────────────────────────────────────────────────

# OIDC issuer URL for enterprise SSO.
# When set, gateway /approve|/reject and UI /api/* routes require a valid Bearer JWT.
# OURO_OIDC_ISSUER=https://your-idp.example.com
